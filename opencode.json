          "~/.local/share/opencode/plans/*": "deny"
        },
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "task": "deny",
        "todowrite": "allow",
        "lsp": "allow",
        "webfetch": "deny",
        "websearch": "deny",
        "external_directory": {
          "*": "deny",
          "~/.local/share/opencode/plans/*": "allow"
        },
        "doom_loop": "deny"
      }
    }
  }
