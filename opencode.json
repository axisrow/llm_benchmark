{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "plan": {
      "permission": {
        "question": "allow",
        "plan_exit": "allow",
        "bash": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "task": "deny",
        "lsp": "allow",
        "webfetch": "deny",
        "websearch": "deny",
        "external_directory": {
